# Render Web Service environment variables for ElectroMart backend
# Copy these keys into Render -> Service -> Environment.

# Render provides PORT automatically, but keeping this here documents expected behavior.
PORT=10000

# MySQL connection details (use your managed database values)
DB_URL=jdbc:mysql://<db-host>:3306/<db-name>?useSSL=true&requireSSL=true&serverTimezone=UTC
DB_USERNAME=<db-username>
DB_PASSWORD=<db-password>

# JWT secret (use a long random string in production)
JWT_SECRET=<strong-random-secret-at-least-64-characters>

# Comma-separated list of allowed frontend origins for CORS
# Example with Vercel + localhost fallback:
APP_CORS_ALLOWED_ORIGINS=https://electro-mart-three.vercel.app,http://localhost:3000,https://*.vercel.app
